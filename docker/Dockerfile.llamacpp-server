# Autostart llama.cpp server for Qwen3.6-35B-A3B (MoE) Q8 GGUF + vision, on RunPod.
#
# - Serves the LLM automatically on startup (OpenAI-compatible at :8000).
# - Also runs sshd so you can SSH in to debug; the container stays up even if the
#   server crashes (start-llama.sh backgrounds it + sleep infinity).
# - Small, fast image (vs the NGC/vLLM stack); no Triton/torch.compile/ptxas dance.
# - Usable for serverless too (swap the trailing `sleep infinity` for the server as
#   the main process / a RunPod handler when you get there).
#
# Base: official llama.cpp CUDA 13 server image, works on RTX PRO 6000 / sm_120.
# NOTE: avoid MXFP4 quants on sm_120; we use Q8_K_P (near-lossless, ~44GB).
FROM ghcr.io/ggml-org/llama.cpp:server-cuda13

RUN apt-get update && apt-get install -y --no-install-recommends \
        openssh-server curl ca-certificates \
    && mkdir -p /run/sshd /models \
    && rm -rf /var/lib/apt/lists/*

# Prefer IPv4 over IPv6 in the resolver. RunPod pods here have dead IPv6 egress,
# and llama.cpp's -hf downloader can't force IPv4 — without this it falls into the
# broken IPv6 path and downloads crawl. This ranks IPv4 ahead so -hf uses it.
RUN echo 'precedence ::ffff:0:0/96  100' >> /etc/gai.conf

COPY docker/start-llama.sh /start-llama.sh
RUN chmod +x /start-llama.sh

# The llama.cpp binary and its shared libs live in /app; our custom entrypoint
# drops the base image's working dir, so make them resolvable explicitly.
ENV PATH=/app:$PATH \
    LD_LIBRARY_PATH=/app

# Defaults — override any of these in the RunPod template env or `docker run -e`.
ENV MODEL_HF_REPO=HauhauCS/Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive \
    MODEL_FILE=Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-Q8_K_P.gguf \
    MMPROJ_FILE=mmproj-Qwen3.6-35B-A3B-Uncensored-HauhauCS-Aggressive-f16.gguf \
    ENABLE_VISION=1 \
    ALIAS=qwen3.6 \
    PORT=8000 \
    CTX=0 \
    NGL=99
# MODELS_DIR / LLAMA_CACHE are intentionally NOT set here — start-llama.sh
# auto-detects the volume mount (/runpod-volume, /workspace, or local /models).
# Set MODELS_DIR explicitly only to override that.

EXPOSE 22 8000
ENTRYPOINT ["/start-llama.sh"]
