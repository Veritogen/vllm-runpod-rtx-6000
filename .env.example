# Copy to .env and fill in. Never commit the real .env.

# --- Model (required) -------------------------------------------------------
# HF repo id of the Qwen3.6 finetune, or a local path under the network volume.
MODEL_ID=your-org/your-qwen3.6-finetune
# Only if the HF repo is private:
# HF_TOKEN=hf_xxx

# --- vLLM launch tuning (optional; defaults live in scripts/start-vllm.sh) ---
MAX_MODEL_LEN=32768
GPU_MEM_UTIL=0.92
# Set to fp8 or auto_round only if the finetune ships in that format; empty = native bf16.
# QUANTIZATION=fp8

# --- Endpoint under test (scripts/test_endpoint.py) -------------------------
# Phase 1 pod (run the test from inside the pod):
BASE_URL=http://localhost:8000/v1
API_KEY=EMPTY
# Phase 2 serverless (replace ENDPOINT_ID, use your RunPod API key):
# BASE_URL=https://api.runpod.ai/v2/<ENDPOINT_ID>/openai/v1
# API_KEY=<RUNPOD_API_KEY>
